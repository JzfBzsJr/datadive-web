{
  "builds": [
    {
      "src": "api/datadive.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/datadive",
      "dest": "api/datadive.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
